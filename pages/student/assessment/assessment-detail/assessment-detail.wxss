.container {
  min-height: 100vh;
  background-color: #fff;
  padding-bottom: 120rpx;
}

.header-info {
  padding: 40rpx 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 16rpx;
}

.progress-box {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.quiz-container {
  padding: 0 32rpx;
}

.question-card {
  margin-bottom: 60rpx;
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.question-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 32rpx;
  display: block;
}

.radio-group {
  display: block;
}

.custom-radio {
  margin-bottom: 24rpx;
  background-color: #f5f5f7;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 4rpx solid transparent;
}

.radio-active {
  background-color: #eef3ff;
  border-color: #0052d9;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 32rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 24rpx;
}

.btn-submit,
.btn-prev {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-prev {
  color: #0052d9;
  background-color: #f5f5f7;
}
